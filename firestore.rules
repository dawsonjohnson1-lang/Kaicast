rules_version = '2';

// Kaicast Firestore security rules.
//   - users/{uid}      — readable by anyone, writable only by the
//                        authenticated owner
//   - diveLogs/{logId} — readable by anyone (privacy filtering is
//                        enforced client-side via the privacy field
//                        for now), creatable by the authed owner,
//                        updatable / deletable only by the owner
//   - spots/{spotId}   — readable by anyone, writable only by
//                        server-side admin (seed script)
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if true;

      // Canonical Settings fields (profile.*, prefs.*, meta.*, phone)
      // are server-only — the `updateUserSetting` callable validates +
      // writes them via Admin SDK. Direct client writes to those keys
      // are denied; legacy / non-canonical fields (displayName, handle,
      // bio, photoURL, the mobile onboarding fields) remain owner-
      // writeable here so onboarding + edit-profile keep working
      // without round-tripping through a callable for every field.
      //
      // Role + entitlement fields are also server-only:
      //   accountType, orgId  — set by provisionCharterOperator + the
      //                          crew invite-accept callable. A client
      //                          cannot self-promote to 'charter' / 'crew'.
      //   orgMemberships      — written by the invite-accept callable.
      //   proAccess, proSource — written by the entitlement Function
      //                          on membership / subscription change.
      // `activeContext` IS client-writable — it's the per-user
      // last-used context toggle from the global account switcher and
      // can be flipped on every navigation.
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny([
                           'profile', 'prefs', 'meta', 'phone',
                           'accountType', 'orgId', 'orgMemberships',
                           'activeOrgIds',
                           'proAccess', 'proSource',
                         ]);
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Per-user favorites subcollection: users/{uid}/favorites/{spotId}
      // Public read (for follower-style "their favorite spots" UI later)
      // but only the owner can write.
      match /favorites/{spotId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Following: users/{uid}/following/{otherUid}
      // Public read so anyone can see who I follow (social graph is
      // intentionally open). Only the owner of this side of the edge
      // can write — i.e. I can only manage my own following list.
      match /following/{otherUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Followers: users/{uid}/followers/{otherUid}
      // Public read. The follower (otherUid) is the one who writes
      // their own entry into my followers when they follow me — the
      // doc id must equal request.auth.uid so nobody can fabricate
      // followers for someone else.
      match /followers/{otherUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == otherUid;
      }

      // Push device tokens: users/{uid}/devices/{tokenId}
      // Owner-only read AND write — push tokens are sensitive enough
      // that we don't want them publicly readable.
      match /devices/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Aggregated user stats: users/{uid}/stats/summary.
      // Only the `aggregateUserStats` Cloud Function writes here (uses
      // Admin SDK, bypasses rules). Public read so other divers' stats
      // can be shown on social/profile views without an auth round-trip.
      match /stats/{statId} {
        allow read:  if true;
        allow write: if false;
      }
    }

    // diveLogs/{logId} is the canonical dive_observation. Writes are
    // server-only (via the submitDiveLog callable, which uses Admin
    // SDK and bypasses these rules). Reads are restricted so a buggy
    // or malicious client can't scrape the full corpus:
    //   - the authenticated author of the log, OR
    //   - any log a guide has reviewed and explicitly verified
    //     (verified_by_guide != null). Public community feed (when
    //     it ships) gets a separate `public: true` flag + rule.
    match /diveLogs/{logId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.uid
                      || resource.data.verified_by_guide != null);
      allow write: if false;
    }

    // Hourly per-spot snapshot doc. Public read so the client app
    // can render without an auth round-trip. Writes are server-only.
    match /kaicast_reports/{reportId} {
      allow read:  if true;
      allow write: if false;
    }

    // Live alert feed surfaced in the SpotAlerts panel (per-spot) and
    // the dashboard ConditionAlerts card. Writes are server-only,
    // produced by the notification engine in functions/notifications/.
    // Public read so the unauthenticated marketing site can render
    // alerts alongside conditions — matches kaicast_reports pattern.
    match /spot_alerts/{alertId} {
      allow read:  if true;
      allow write: if false;
    }

    // Rolling community-observed conditions overlay per spot.
    // Updated transactionally by submitDiveLog. Public read.
    match /community_overlays/{spotId} {
      allow read:  if true;
      allow write: if false;
    }

    // Per-spot calibration bias offsets (server-managed by future
    // nightly job). Public read so the client can show "model
    // calibration: ±2 ft at this spot" later.
    match /abyss_calibration/{spotId} {
      allow read:  if true;
      allow write: if false;
    }

    // Per-spot daily rollup stats. Server-managed, public read.
    match /spot_stats/{spotId}/{document=**} {
      allow read:  if true;
      allow write: if false;
    }

    // abyss_diver_reports is deprecated and drained
    // (scripts/drain-abyss-diver-reports.mjs). diveLogs now carries
    // deltas + predicted_at_time inline. Rule kept as a tripwire so
    // anything inadvertently re-creating the collection is denied.
    match /abyss_diver_reports/{document=**} {
      allow read:  if false;
      allow write: if false;
    }

    match /spots/{spotId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Charter dashboard (a separate product on the same Firestore) ──
    //
    // The charter dashboard is gated to users whose users/{uid} doc has
    // accountType == 'charter' AND orgId set to the matching org. The
    // org doc + its three subcollections (crew, spots, trips) are
    // readable only by users from the same org; writes are likewise
    // owner-scoped. Consumer accounts have no path into any charter
    // data — the rules + the route guard in App.tsx are independent
    // defenses for the same invariant.
    //
    // The trip share link route (/charter/brief/:tripId?t=<token>)
    // intentionally needs no auth — but the rule still denies blind
    // reads. The Phase 6 implementation routes the public brief
    // through a Cloud Function that validates the token server-side
    // and returns just the brief subset; the trip doc itself stays
    // owner-scoped.

    function isCharterMember(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'charter'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    // Crew-side access for a specific org.
    //
    // Backed by users/{uid}.activeOrgIds — a denormalized string array
    // maintained by acceptCrewInvitation. We can't introspect the
    // structured orgMemberships array from rules (each entry is an
    // object), so activeOrgIds is the rule-friendly mirror of the
    // "which orgs am I active in right now?" question.
    function hasActiveCrewMembership(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeOrgIds is list
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeOrgIds.hasAny([orgId]);
    }

    // Union of admin + crew access for an org. Most read rules use
    // this; writes stay scoped to admin unless explicitly broadened.
    function hasOrgAccess(orgId) {
      return isCharterMember(orgId) || hasActiveCrewMembership(orgId);
    }

    match /charter_accounts/{orgId} {
      // Org doc — read by admin OR any active crew member (crew need
      // the org name + harbor info to render their dashboard). Writes
      // (rename, harbor change) stay admin-only; the seed flow uses
      // Admin SDK.
      allow read:   if hasOrgAccess(orgId);
      allow update: if isCharterMember(orgId);
      // Create + delete are intentionally denied — orgs are provisioned
      // server-side so a single uid can't fork a fresh org for itself.
      allow create, delete: if false;

      match /crew/{crewId} {
        // Roster:
        //   - Admin reads + writes everything.
        //   - Active crew can read the FULL roster (the /crew/brief
        //     screen renders a list of names + roles for the crew on
        //     a trip; per-doc filtering would mean N reads instead of
        //     one collection scan).
        //   - Active crew may update ONLY the certs field on their
        //     OWN record. Role / uid / other-fields stay admin-only,
        //     and writes against another member's record stay denied.
        allow read:   if hasOrgAccess(orgId);
        allow create, delete: if isCharterMember(orgId);
        allow update: if isCharterMember(orgId)
                      || (hasActiveCrewMembership(orgId)
                          && resource.data.uid == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['certs']));
      }

      match /spots/{spotId} {
        // Private spot library. Crew reads (for trip brief context);
        // only admin writes.
        allow read:  if hasOrgAccess(orgId);
        allow write: if isCharterMember(orgId);
      }

      match /trips/{tripId} {
        // Trip docs. Readable by admin OR any active crew member of
        // the org — the My Trips screen filters client-side to the
        // ones the caller is actually on. Writes (creating/editing
        // trips, filing float plan + log) stay admin-only for D2;
        // captain-scoped writes land in Slice D3. The public brief
        // share goes through a Cloud Function that validates the
        // token — the doc itself is NOT publicly readable.
        allow read:  if hasOrgAccess(orgId);
        allow write: if isCharterMember(orgId);
      }

      match /alerts/{alertId} {
        // Good Window alerts — readable by any member of the org so
        // the dashboard banner surfaces them; writes restricted to
        // (1) the charterGoodWindowAlerter Cloud Function (Admin SDK
        // bypasses rules) which CREATES alerts, and (2) any org
        // member toggling read/unread state from the dashboard.
        // Direct create from a client is denied so a bad actor can't
        // synthesize fake alerts; the rule below only allows updates
        // to specific harmless fields.
        allow read:   if isCharterMember(orgId);
        allow update: if isCharterMember(orgId)
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['read', 'readAt']);
        allow create, delete: if false;
      }

      // ── FareHarbor integration (Phase 9) ──────────────────────────
      //
      // integrations/{provider} — connection metadata + the (sensitive)
      // userApiKey. Readable by org members; writable for the
      // shortname/userApiKey/connectedAt subset only (server functions
      // patch the operational fields like lastSync, syncStatus, etc).
      // Clients use the validateFareHarborCredentials callable before
      // writing here — direct rule-level validation can't reach
      // FareHarbor, so the callable is the real gate.
      match /integrations/{provider} {
        allow read: if isCharterMember(orgId);
        // Clients can write the connection inputs (shortname,
        // userApiKey, connectedAt) and optionally clear the integration
        // by deleting the doc. The sync function (Admin SDK) writes
        // lastSync / syncStatus / errorMsg / tripCount / itemCount.
        allow create, update: if isCharterMember(orgId)
                              && request.resource.data.diff(resource.data).affectedKeys()
                                   .hasOnly(['shortname','userApiKey','connectedAt',
                                             'lastSync','syncStatus','errorMsg','tripCount','itemCount']);
        allow delete: if isCharterMember(orgId);
      }

      // fh_items — FareHarbor product catalog mirror PLUS charter
      // enrichment fields (tripType, boatIds, harborId,
      // kaicastSpotIds, notes, enriched). The sync function writes
      // the FH subset; clients write the enrichment subset via the
      // Settings → Products UI.
      match /fh_items/{itemId} {
        allow read: if isCharterMember(orgId);
        // No allow-list at the field level — clients can patch any
        // field. The sync function uses merge:true so client
        // enrichments survive each sync. If a client writes a bad
        // tripType the trip wizard's validation catches it; nothing
        // here can corrupt other orgs' data because the path is
        // org-scoped.
        allow write: if isCharterMember(orgId);
      }

      // fh_trips — synced availability mirror. Read by org members
      // (the /charter/trips page renders these). All writes are
      // server-only — the sync function and webhook both use Admin
      // SDK and bypass these rules; client writes are denied so a
      // bad actor can't synthesize fake trips or fake cancellations.
      match /fh_trips/{tripId} {
        allow read:  if isCharterMember(orgId);
        allow write: if false;
      }

      // boats — per-charter boat roster. Used by the enrichment
      // drawer's "Assigned boats" multi-select. Org-scoped writes.
      match /boats/{boatId} {
        allow read, write: if isCharterMember(orgId);
      }
    }

    // Global harbor reference data. Public read so an unauthenticated
    // brief share or marketing page can render harbor names + coords.
    // Writes are admin-only (the seedHarbors callable uses Admin SDK).
    match /harbors/{harborId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Crew invitations ───────────────────────────────────────────────
    //
    // A pending pointer from a charter admin to a future crew member.
    // Writes are server-only (the createCrewInvitation callable creates
    // them; acceptCrewInvitation flips status to 'accepted' and patches
    // the invitee's orgMemberships). Reads are allowed for:
    //   - charter admins of the matching orgId — so they can see the
    //     pending invites they've sent on the Crew screen
    //   - the invitee themselves, matched by auth-token email — so they
    //     can hit the public /invite/:inviteId page and see the org
    //     name, role, and expiry without first becoming a member
    //
    // Email match is case-sensitive at the rule level. The callable
    // lowercases invitedEmail on write, and Firebase Auth lowercases
    // tokens, so equality holds in practice. If a future signup flow
    // bypasses Auth's normalization, switch to .lower() on both sides.
    match /crew_invitations/{inviteId} {
      allow read: if request.auth != null && (
        isCharterMember(resource.data.orgId)
        || (request.auth.token.email != null
            && request.auth.token.email == resource.data.invitedEmail)
      );
      allow create, update, delete: if false;
    }
  }
}
