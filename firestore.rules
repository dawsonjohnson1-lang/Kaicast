rules_version = '2';

// KaiCast Firestore rules.
//
// Public reads: kaicast_reports, spots_latest, spots, condition_alerts, meta.
// Authenticated writes: community_reports (user can only write a report
// where userId matches their auth uid).
// Cloud Functions (admin SDK) bypass rules entirely.

service cloud.firestore {
  match /databases/{database}/documents {

    match /kaicast_reports/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /spots_latest/{spotId} {
      allow read: if true;
      allow write: if false;
    }

    match /spots/{spotId} {
      allow read: if true;
      allow write: if false;
    }

    match /condition_alerts/{alertId} {
      allow read: if true;
      allow write: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /community_reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Per-user document for saved spots, settings.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
