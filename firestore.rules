rules_version = '2';

// Kaicast Firestore security rules.
//   - users/{uid}      — readable by anyone, writable only by the
//                        authenticated owner
//   - diveLogs/{logId} — readable by anyone (privacy filtering is
//                        enforced client-side via the privacy field
//                        for now), creatable by the authed owner,
//                        updatable / deletable only by the owner
//   - spots/{spotId}   — readable by anyone, writable only by
//                        server-side admin (seed script)
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Per-user favorites subcollection: users/{uid}/favorites/{spotId}
      // Public read (for follower-style "their favorite spots" UI later)
      // but only the owner can write.
      match /favorites/{spotId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Following: users/{uid}/following/{otherUid}
      // Public read so anyone can see who I follow (social graph is
      // intentionally open). Only the owner of this side of the edge
      // can write — i.e. I can only manage my own following list.
      match /following/{otherUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Followers: users/{uid}/followers/{otherUid}
      // Public read. The follower (otherUid) is the one who writes
      // their own entry into my followers when they follow me — the
      // doc id must equal request.auth.uid so nobody can fabricate
      // followers for someone else.
      match /followers/{otherUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == otherUid;
      }

      // Push device tokens: users/{uid}/devices/{tokenId}
      // Owner-only read AND write — push tokens are sensitive enough
      // that we don't want them publicly readable.
      match /devices/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /diveLogs/{logId} {
      allow read: if true;
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.uid;
    }

    match /spots/{spotId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
