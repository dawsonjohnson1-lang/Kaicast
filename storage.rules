rules_version = '2';

// KaiCast Cloud Storage rules.
//
// Layout:
//   users/{uid}/dives/{logId}/{filename}
//     Per-user dive-photo uploads. Owner-only write, public read so the
//     SpotDetail "Photo highlights" grid (future) and shared dive logs
//     can surface them without a signed-URL fan-out per viewer. If
//     moderation is needed later, swap public read for a metadata
//     `approved == true` gate.
//
// Constraints:
//   - 10 MB per file (matches the dropzone copy: "JPG / PNG / HEIC · up to 10MB each")
//   - image/* content type only
//   - filename length capped to keep paths sane
//
// Anything outside users/{uid}/dives is denied by default.

service firebase.storage {
  match /b/{bucket}/o {

    match /users/{uid}/dives/{logId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && filename.size() < 200;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
