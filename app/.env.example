# Public token — shipped in the JS bundle, safe to commit a placeholder
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Secret download token — used at BUILD TIME only to pull the
# Mapbox iOS/Android SDKs. Never commit a real value.
MAPBOX_DOWNLOADS_TOKEN=sk.your_secret_download_token_here

# Static satellite imagery is now sourced from ESRI World Imagery via
# `app/src/api/satellite.ts` — no API key is required. Attribution
# ("Source: Esri, Maxar, Earthstar Geographics") belongs in the app's
# Legal / About screen, not on the image itself. To swap back to Google
# Maps Static, see the comment at the top of satellite.ts.

# ── Firebase Web App config ──────────────────────────────────────────
# Copy from https://console.firebase.google.com/project/kaicast-207dc/settings/general
# (Your apps → Web app → Config). All six values are required for the
# client to initialize Firebase Auth + Firestore + Storage. When ANY
# are missing the app falls back to a local AsyncStorage stub so demo
# mode keeps working — auth uses email-derived fake accounts, dive
# logs queue locally, profile stays static.
EXPO_PUBLIC_FIREBASE_API_KEY=AIza_your_web_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=kaicast-207dc.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=kaicast-207dc
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=kaicast-207dc.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_app_id_here
