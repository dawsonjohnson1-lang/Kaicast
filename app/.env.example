# Public token — shipped in the JS bundle, safe to commit a placeholder
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Secret download token — used at BUILD TIME only to pull the
# Mapbox iOS/Android SDKs. Never commit a real value.
MAPBOX_DOWNLOADS_TOKEN=sk.your_secret_download_token_here

# Google Maps Static API key — single source for every static satellite
# image in the app (spot heroes, saved/featured/explore cards,
# Wind/Current compass backgrounds). Mapbox stays reserved for the live
# interactive map on the Explore tab. EXPO_PUBLIC_* vars are inlined
# into the JS bundle at build time. Restrict this key to Maps Static +
# iOS bundle id / Android package in the Google Cloud console before
# committing it to a real .env on a shared machine.
#
# EXPO_PUBLIC_GOOGLE_MAPS_KEY is the canonical name read by
# app/src/api/satellite.ts; EXPO_PUBLIC_GOOGLE_MAPS_API_KEY is honored
# as a back-compat fallback.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_static_api_key_here
