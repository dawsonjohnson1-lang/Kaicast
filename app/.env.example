# Firebase web config — fill these in from
# https://console.firebase.google.com/project/kaicast/settings/general/web
# Then either rename this file to .env (loaded by Expo at start time)
# or paste the values into app.json `extra.firebase`.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=kaicast.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=kaicast
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=kaicast.appspot.com
