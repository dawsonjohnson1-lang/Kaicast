# Copy this file to .env and fill in real values.
# Vite exposes any VITE_* variable to client code at build time.

# Mapbox GL JS access token. Create one at https://account.mapbox.com/access-tokens/
# A public pk.* token is fine — restrict it by URL (kaicast-207dc-5d2f2.web.app + localhost:5173) in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=pk.your_token_here

# OpenWeatherMap API key. Free tier is fine for dev (60 calls/min, 1M/mo).
# At production scale you'll need their "Startup" plan (~$40/mo for 60M/mo)
# OR a Cloud Functions tile proxy in front of OWM. See architecture doc.
# IMPORTANT: this key is bundled into the client JS — scope it via
# https://home.openweathermap.org/api_keys → "Allowed Origins" to lock it
# down to your domains (localhost:5173, *.kaicast-207dc-5d2f2.web.app,
# app.kaicast.com).
VITE_OPENWEATHER_TOKEN=your_owm_key_here

# Firebase Web App config. Pull from:
#   https://console.firebase.google.com/project/kaicast-207dc/settings/general
# Public — these values are designed to be in client bundles. Firestore
# security rules enforce access; auth tokens enforce per-user access.
# Used by the visibility heatmap (and any future Firestore-backed
# desktop features) to read public collections like community_overlays
# and spots.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
