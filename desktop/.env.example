# Copy this file to .env and fill in real values.
# Vite exposes any VITE_* variable to client code at build time.

# Mapbox GL JS access token. Create one at https://account.mapbox.com/access-tokens/
# A public pk.* token is fine — restrict it by URL (kaicast-207dc-5d2f2.web.app + localhost:5173) in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=pk.your_token_here

# OpenWeatherMap API key. Free tier is fine for dev (60 calls/min, 1M/mo).
# At production scale you'll need their "Startup" plan (~$40/mo for 60M/mo)
# OR a Cloud Functions tile proxy in front of OWM. See architecture doc.
# IMPORTANT: this key is bundled into the client JS — scope it via
# https://home.openweathermap.org/api_keys → "Allowed Origins" to lock it
# down to your domains (localhost:5173, *.kaicast-207dc-5d2f2.web.app,
# app.kaicast.com).
VITE_OPENWEATHER_TOKEN=your_owm_key_here

# Firebase Web App config. Pull from:
#   https://console.firebase.google.com/project/kaicast-207dc/settings/general
# Public — these values are designed to be in client bundles. Firestore
# security rules enforce access; auth tokens enforce per-user access.
# Used by the visibility heatmap (and any future Firestore-backed
# desktop features) to read public collections like community_overlays
# and spots.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry error tracking. OPTIONAL — leave blank and the app runs exactly
# as before (no error reporting). To enable:
#   1. Create a React project at https://sentry.io and copy its DSN.
#   2. Set VITE_SENTRY_DSN below. The DSN is public-safe (it's designed
#      to live in client bundles; it only allows *sending* events).
# Free Developer plan covers 5K errors/mo — plenty pre-launch.
VITE_SENTRY_DSN=
# Optional: tie each error to a deploy (e.g. a git short sha). Without it
# errors group under an "unknown" release.
VITE_SENTRY_RELEASE=

# Source-map upload (build-time only, NOT VITE_* — never shipped to the
# client). Set these THREE in your CI / hosting build env so `npm run
# build` uploads source maps and minified stack traces become readable.
# Leave unset for a normal build (no maps generated, no upload).
#   SENTRY_AUTH_TOKEN=   (https://sentry.io → Settings → Auth Tokens)
#   SENTRY_ORG=          (your Sentry org slug)
#   SENTRY_PROJECT=      (the project slug you created above)
